{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=BaseTemplateDb;User Id=sa;Password=Your_password123;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Issuer": "BaseTemplate.API",
    "Audience": "BaseTemplate.Client",
    "SigningKey": "REPLACE_WITH_A_SECRET_LOADED_FROM_USER_SECRETS_OR_ENV_VAR_32CHARS",
    "ExpiryMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200", "http://localhost:4300", "http://localhost:4400" ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "app_data/logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "AllowedHosts": "*"
}
